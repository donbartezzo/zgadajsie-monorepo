# ─── Database ───
DATABASE_URL="postgresql://zgadaj_user:furGit320abc@localhost:5433/zgadaj_db?schema=public"

# ─── JWT ───
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── URLs ───
BACKEND_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:4300"

# ─── SMTP (Email) ───
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@zgadajsie.pl"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@zgadajsie.pl"

# ─── Web Push (VAPID) ───
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:kontakt@zgadajsie.pl"

# ─── Cloudflare R2 (Storage) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="zgadajsie-media"
R2_PUBLIC_URL=""

# ─── Tpay (Payments) ───
# For development/testing: https://api.sandbox.tpay.com
# For production: https://api.tpay.com
TPAY_API_URL="https://api.sandbox.tpay.com"
TPAY_CLIENT_ID=""
TPAY_CLIENT_SECRET=""
TPAY_MERCHANT_ID=""
# Security code for webhook md5sum verification (Merchant Panel → Notifications → Security)
TPAY_SECURITY_CODE=""

# ─── Google OAuth2 ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="${BACKEND_URL}/api/auth/google/callback"

# ─── Facebook OAuth2 ───
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="${BACKEND_URL}/api/auth/facebook/callback"
