# ─── Database ───
DATABASE_URL="postgresql://user:password@localhost:5432/zgadajsie?schema=public"

# ─── JWT ───
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── Frontend ───
FRONTEND_URL="http://localhost:4200"
CORS_ORIGINS="http://localhost:4200"
PORT=3000

# ─── SMTP (Email) ───
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="noreply@zgadajsie.pl"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@zgadajsie.pl"

# ─── Web Push (VAPID) ───
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:kontakt@zgadajsie.pl"

# ─── Cloudflare R2 (Storage) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="zgadajsie-media"
R2_PUBLIC_URL=""

# ─── Tpay (Payments) ───
TPAY_API_URL="https://secure.sandbox.tpay.com"
TPAY_MERCHANT_ID=""
TPAY_SECURITY_CODE=""

# ─── Google OAuth2 ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ─── Facebook OAuth2 ───
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:3000/api/auth/facebook/callback"
