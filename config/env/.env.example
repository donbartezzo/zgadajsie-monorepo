# Jeśli coś zmieniasz/dodajesz pamiętaj żeby zrobić to także w Environment Variables w Coolify dla dev i prod.

# ─── Database ───
DATABASE_URL="postgresql://zgadaj_user:furGit320abc@localhost:5433/zgadaj_db?schema=public"

# ─── JWT ───
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── URLs ───
BACKEND_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:4300"

# ─── Email (Resend) ───
# Klucz API z https://resend.com - wymagany
RESEND_API_KEY="re_..."
# Adres nadawcy (musi być z zweryfikowanej domeny w Resend)
EMAIL_FROM="kontakt@zgadajsie.pl"
# Email admina do powiadomień systemowych (cron monitor, alerty)
ADMIN_EMAIL="admin@zgadajsie.pl"

# ─── Web Push (VAPID) ───
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:kontakt@zgadajsie.pl"

# ─── Cloudflare Turnstile (Captcha) ───
# Dev/test keys (always-pass): https://developers.cloudflare.com/turnstile/reference/testing/
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
# For production: replace with real keys from Cloudflare dashboard

# ─── Cloudflare R2 (Storage) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Bucket per środowisko (dane userów, media eventów): prod=zgadajsie-media-prod, dev=zgadajsie-media-dev
R2_BUCKET_NAME="zgadajsie-media-dev"
R2_PUBLIC_URL=""
# Wspólny bucket publiczny (covery dyscyplin zarządzane przez admina) - ten sam dla wszystkich środowisk
R2_PUBLIC_BUCKET_NAME="zgadajsie-media-public"
R2_PUBLIC_BUCKET_URL="https://pub-1ae4230bedb64658a034b3a7c70804c1.r2.dev"
# Zapis do galerii publicznej dozwolony tylko z produkcji: "true" na prodzie, puste/"false" gdzie indziej
PUBLIC_COVERS_WRITABLE=""

# ─── Tpay (Payments) ───
# For development/testing: https://api.sandbox.tpay.com
# For production: https://api.tpay.com
TPAY_API_URL="https://api.sandbox.tpay.com"
TPAY_CLIENT_ID=""
TPAY_CLIENT_SECRET=""
TPAY_MERCHANT_ID=""
# Security code for webhook md5sum verification (Merchant Panel → Notifications → Security)
TPAY_SECURITY_CODE=""

# ─── Google OAuth2 ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="${BACKEND_URL}/api/auth/google/callback"

# ─── Facebook OAuth2 ───
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="${BACKEND_URL}/api/auth/facebook/callback"

# ─── Temporary feature flags ───
# Source of truth: libs/src/lib/config/runtime-config.ts
# Override defaults by setting these environment variables

# Maintenance mode (default: false)
# MAINTENANCE="true"

# Disable social login (default: true for both)
# DISABLE_GOOGLE_LOGIN="false"
# DISABLE_FACEBOOK_LOGIN="false"

# Disable event creation (default: false)
# DISABLE_EVENT_CREATION="true"

# Disable online payments (default: true)
# DISABLE_ONLINE_PAYMENTS="false"
