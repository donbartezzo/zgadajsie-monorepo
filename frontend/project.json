{
  "name": "frontend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "frontend/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["frontend:version:ci", "frontend:tokens:generate"],
      "options": {
        "outputPath": "dist/frontend",
        "browser": "frontend/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "frontend/tsconfig.app.json",
        "serviceWorker": "frontend/ngsw-config.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "frontend/public"
          },
          "frontend/src/manifest.webmanifest"
        ],
        "styles": ["frontend/src/styles.scss"]
      },
      "configurations": {
        "local": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "frontend/src/environments/environment.ts",
              "with": "frontend/src/environments/environment.local.ts"
            }
          ]
        },
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "frontend/src/environments/environment.ts",
              "with": "frontend/src/environments/environment.production.ts"
            }
          ]
        },
        "dev-server": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "frontend/src/environments/environment.ts",
              "with": "frontend/src/environments/environment.local.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4300,
        "proxyConfig": "frontend/proxy.conf.js"
      },
      "configurations": {
        "production": {
          "buildTarget": "frontend:build:production"
        },
        "local": {
          "buildTarget": "frontend:build:local"
        }
      },
      "defaultConfiguration": "local"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "frontend:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "dependsOn": ["frontend:version:ci"],
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "frontend/jest.config.ts",
        "tsConfig": "frontend/tsconfig.spec.json"
      },
      "configurations": {
        "ci": {
          "jestConfig": "frontend/jest.config.ts",
          "tsConfig": "frontend/tsconfig.spec.json",
          "options": {
            "--no-warnings": true
          }
        }
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "frontend:build",
        "port": 4300,
        "staticFilePath": "dist/frontend/browser",
        "spa": true
      }
    },
    "start-db": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d"
      }
    },
    "version:ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "GENERATE_FRONTEND_VERSION=true node scripts/generate-frontend-version.mjs"
      }
    },
    "tokens:generate": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/frontend/src/styles/_tokens.scss"],
      "inputs": [
        "{workspaceRoot}/libs/src/lib/constants/color-palette.json",
        "{workspaceRoot}/libs/src/lib/constants/semantic-color-mapping.json",
        "{workspaceRoot}/scripts/generate-color-tokens.mjs"
      ],
      "options": {
        "command": "node scripts/generate-color-tokens.mjs"
      }
    }
  }
}
