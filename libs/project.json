{
  "name": "libs",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs"],
      "options": {
        "command": "libs/run-jest.sh --passWithNoTests"
      },
      "configurations": {
        "ci": {
          "command": "libs/run-jest.sh --passWithNoTests --ci --no-warnings"
        }
      }
    }
  }
}
