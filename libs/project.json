{
  "name": "libs",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs"],
      "options": {
        "command": "jest --config libs/jest.config.ts --passWithNoTests",
        "env": {
          "NODE_OPTIONS": "--experimental-vm-modules"
        }
      },
      "configurations": {
        "ci": {
          "command": "jest --config libs/jest.config.ts --passWithNoTests --ci --no-warnings",
          "env": {
            "NODE_OPTIONS": "--experimental-vm-modules"
          }
        }
      }
    }
  }
}
