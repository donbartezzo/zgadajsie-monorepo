{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "rootDir": ".",
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "src/**/*.json", "email/src/**/*.{ts,tsx}"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
