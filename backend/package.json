{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc --project tsconfig.app.json",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:db": "docker compose up -d",
    "prisma": "prisma",
    "db:seed": "dotenv -e .env -- npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "dotenv -e .env -- tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/jest": "^29.5.12",
    "@types/node": "20.19.9",
    "dotenv-cli": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
