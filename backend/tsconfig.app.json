{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "commonjs",
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "composite": true,
    "declaration": true
  },
  "include": ["src/**/*.ts", "../libs/src/**/*.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts", "../libs/src/**/*.spec.ts", "../libs/src/**/*.test.ts"]
}
