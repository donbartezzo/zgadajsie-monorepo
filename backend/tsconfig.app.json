{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "commonjs",
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "composite": true,
    "declaration": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*.{ts,tsx}",
    "../libs/src/**/*.ts",
    "../libs/src/**/*.json",
    "../libs/email/src/**/*.{ts,tsx}"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../libs/src/**/*.spec.ts",
    "../libs/src/**/*.test.ts",
    "../libs/email/src/**/__tests__/**",
    "../libs/email/src/**/*.spec.ts",
    "../libs/email/src/**/*.spec.tsx",
    "../libs/email/src/**/*.test.ts",
    "../libs/email/src/**/*.test.tsx"
  ]
}
