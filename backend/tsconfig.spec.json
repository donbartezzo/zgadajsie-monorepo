{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc",
    "module": "commonjs",
    "moduleResolution": "node10",
    "types": ["jest", "node"],
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "../libs/email/src/**/*.ts",
    "../libs/email/src/**/*.tsx",
    "../libs/src/**/*.ts"
  ]
}
