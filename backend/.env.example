# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/zgadajsie?schema=public

# JWT
JWT_SECRET=your-jwt-secret-change-me
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-me
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@zgadajsie.pl

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=zgadajsie
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# Tpay
TPAY_CLIENT_ID=your-tpay-client-id
TPAY_CLIENT_SECRET=your-tpay-client-secret
TPAY_MERCHANT_ID=your-tpay-merchant-id
TPAY_API_URL=https://openapi.sandbox.tpay.com
TPAY_NOTIFICATION_URL=http://localhost:3000/api/wallets/tpay-notification

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@zgadajsie.pl
