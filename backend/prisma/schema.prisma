generator client {
  provider        = "prisma-client-js"
  // omitApi: pozwala pomijać skalary w wynikach zapytań (np. event.coverImageId).
  // GA w Prisma 6.x - przy upgradzie usunąć z previewFeatures.
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                  @id @default(uuid())
  email                       String                  @unique
  passwordHash                String?
  displayName                 String
  role                        Role                    @default(USER)
  isActive                    Boolean                 @default(false)
  isEmailVerified             Boolean                 @default(false)
  activationToken             String?
  activationTokenExpiresAt    DateTime?
  passwordResetToken          String?
  passwordResetTokenExpiresAt DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  tpayMerchantId              String?
  donationUrl                 String?
  avatarSeed                  String?
  weeklyDigestSentAt          DateTime?
  accountType                 AccountType             @default(REAL)
  gender                      Gender?
  welcomeMessage              String?
  welcomeMessageEnabled       Boolean                 @default(true)
  announcementReceipts        AnnouncementReceipt[]
  citySubscriptions           CitySubscription[]
  organizedEvents             Event[]                 @relation("OrganizerEvents")
  announcements               EventAnnouncement[]     @relation("OrganizerAnnouncements")
  groupChatMessages           EventGroupMessage[]
  addedEnrollments            EventEnrollment[]       @relation("AddedByUser")
  enrollments                 EventEnrollment[]       @relation("UserEnrollments")
  eventSeries                 EventSeries[]
  mediaFiles                  MediaFile[]
  notifications               Notification[]
  organizerRelations          OrganizerUserRelation[] @relation("OrgRelOrganizer")
  targetOfRelations           OrganizerUserRelation[] @relation("OrgRelTarget")
  vouchersIssued              OrganizerVoucher[]      @relation("VoucherOrganizer")
  vouchersReceived            OrganizerVoucher[]      @relation("VoucherRecipient")
  payments                    Payment[]               @relation("UserPayments")
  paymentIntents              PaymentIntent[]         @relation("UserPaymentIntents")
  privateChatMessagesReceived PrivateChatMessage[]    @relation("PrivateChatRecipient")
  privateChatMessagesSent     PrivateChatMessage[]    @relation("PrivateChatSender")
  pushSubscriptions           PushSubscription[]
  reprimandsGiven             Reprimand[]             @relation("ReprimandFrom")
  reprimandsReceived          Reprimand[]             @relation("ReprimandTo")
  socialAccounts              SocialAccount[]
  coverImages                 CoverImage[]            @relation("UserCoverImages")
  contactMessages             ContactMessage[]

  @@index([accountType])
}

model SocialAccount {
  id             String         @id @default(uuid())
  userId         String
  provider       SocialProvider
  providerUserId String
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model City {
  slug          String             @id
  name          String
  isActive      Boolean            @default(false)
  province      String?
  lat           Float?
  lng           Float?
  priority      Int                @default(0)
  subscriptions CitySubscription[]
  events        Event[]

  @@index([priority])
}

model EventDiscipline {
  slug        String       @id
  schema      Json?
  coverImages CoverImage[]
  events      Event[]
}

model CoverImage {
  id             String           @id @default(uuid())
  disciplineSlug String?
  filename       String
  storageKey     String?
  ownerUserId    String?
  name           String?
  isDefault      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  discipline     EventDiscipline? @relation(fields: [disciplineSlug], references: [slug])
  owner          User?            @relation("UserCoverImages", fields: [ownerUserId], references: [id], onDelete: Cascade)
  events         Event[]

  @@index([disciplineSlug])
  @@index([ownerUserId])
}

model EventFacility {
  slug   String  @id
  events Event[]
}

model EventLevel {
  slug   String  @id
  weight Int?
  events Event[]
}

model Event {
  id                    String               @id @default(uuid())
  title                 String
  description           String?
  disciplineSlug        String
  facilitySlug          String
  levelSlug             String
  citySlug              String
  organizerId           String
  startsAt              DateTime
  endsAt                DateTime
  costPerPerson         Decimal              @default(0) @db.Decimal(10, 2)
  minParticipants       Int?
  maxParticipants       Int
  ageMin                Int?
  ageMax                Int?
  gender                EventGender          @default(ANY)
  visibility            EventVisibility      @default(PUBLIC)
  status                EventStatus          @default(ACTIVE)
  address               String
  lat                   Float
  lng                   Float
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  rules                 String?
  coverImageId          String?
  lotteryExecutedAt     DateTime?
  roleConfig            Json?
  facilityReserved      Boolean              @default(true)
  seriesId              String?
  confirmToken                  String?              @unique
  welcomeMessageEnabled         Boolean              @default(true)
  city                  City                 @relation(fields: [citySlug], references: [slug])
  coverImage            CoverImage?          @relation(fields: [coverImageId], references: [id])
  discipline            EventDiscipline      @relation(fields: [disciplineSlug], references: [slug])
  facility              EventFacility        @relation(fields: [facilitySlug], references: [slug])
  level                 EventLevel           @relation(fields: [levelSlug], references: [slug])
  organizer             User                 @relation("OrganizerEvents", fields: [organizerId], references: [id])
  series                EventSeries?         @relation("SeriesEvents", fields: [seriesId], references: [id])
  targetOccupancyConfig       EventTargetOccupancyConfig?
  announcements         EventAnnouncement[]
  groupChatMessages     EventGroupMessage[]
  enrollments           EventEnrollment[]
  slots                 EventSlot[]
  notifications         Notification[]       @relation("NotificationEvent")
  issuedVouchers        OrganizerVoucher[]
  payments              Payment[]            @relation("EventPayments")
  paymentIntents        PaymentIntent[]      @relation("EventPaymentIntents")
  privateChatMessages   PrivateChatMessage[]
  reprimands            Reprimand[]

  @@index([citySlug, status, startsAt])
  @@index([seriesId, startsAt])
}

model EventSeries {
  id               String                    @id @default(uuid())
  organizerId      String
  name             String
  recurrenceType   EventSeriesRecurrenceType
  intervalDays     Int?
  daysOfWeek       Int[]
  time             String
  timezone         String
  durationMinutes  Int
  startDate        DateTime
  endDate          DateTime?
  nextGenerationAt DateTime
  lastGeneratedAt  DateTime?
  bufferDays       Int                       @default(30)
  autoCoverImage   Boolean                   @default(false)
  templateSnapshot Json
  isActive         Boolean                   @default(true)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  suspendedAt                  DateTime?
  suspendedReason              String?
  events                       Event[]                   @relation("SeriesEvents")
  organizer        User                      @relation(fields: [organizerId], references: [id])
  targetOccupancyConfig  EventSeriesTargetOccupancyConfig?

  @@index([organizerId])
  @@index([isActive, nextGenerationAt])
}

model EventTargetOccupancyConfig {
  eventId            String @id
  targetOccupancy    Int    @default(35)
  cleanupHours       Int    @default(12)
  minFreeSlotsBuffer Int    @default(3)
  event              Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSeriesTargetOccupancyConfig {
  seriesId           String      @id
  targetOccupancy    Int         @default(35)
  cleanupHours       Int         @default(12)
  minFreeSlotsBuffer Int         @default(3)
  series             EventSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model EventEnrollment {
  id             String          @id @default(uuid())
  eventId        String
  userId         String
  addedByUserId  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  wantsIn        Boolean         @default(true)
  withdrawnBy    WithdrawnBy?
  roleKey        String?
  waitingReason  String?
  addedBy        User?           @relation("AddedByUser", fields: [addedByUserId], references: [id])
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User            @relation("UserEnrollments", fields: [userId], references: [id])
  slot           EventSlot?
  payments       Payment[]
  paymentIntents PaymentIntent[]

  @@unique([eventId, userId])
  @@map("EventParticipation")
}

model EventSlot {
  id           String           @id @default(uuid())
  eventId      String
  enrollmentId String?          @unique @map("participationId")
  confirmed    Boolean          @default(false)
  assignedAt   DateTime?
  createdAt    DateTime         @default(now())
  roleKey      String?
  locked       Boolean          @default(false)
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  enrollment   EventEnrollment? @relation(fields: [enrollmentId], references: [id])

  @@index([eventId])
  @@index([eventId, roleKey])
}

model PaymentIntent {
  id              String          @id @default(uuid())
  enrollmentId    String          @map("participationId")
  userId          String
  eventId         String
  amount          Decimal         @db.Decimal(10, 2)
  voucherReserved Decimal         @default(0) @db.Decimal(10, 2)
  operatorTxId    String?
  createdAt       DateTime        @default(now())
  event           Event           @relation("EventPaymentIntents", fields: [eventId], references: [id])
  enrollment      EventEnrollment @relation(fields: [enrollmentId], references: [id])
  user            User            @relation("UserPaymentIntents", fields: [userId], references: [id])

  @@index([operatorTxId])
  @@index([enrollmentId])
}

model Payment {
  id                String             @id @default(uuid())
  enrollmentId      String             @map("participationId")
  userId            String
  eventId           String
  amount            Decimal            @db.Decimal(10, 2)
  organizerAmount   Decimal            @db.Decimal(10, 2)
  platformFee       Decimal            @db.Decimal(10, 2)
  currency          PaymentCurrency    @default(PLN)
  status            PaymentStatus      @default(COMPLETED)
  operatorTxId      String?
  method            String?
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  voucherAmountUsed Decimal            @default(0) @db.Decimal(10, 2)
  issuedVouchers    OrganizerVoucher[] @relation("VoucherSourcePayment")
  event             Event              @relation("EventPayments", fields: [eventId], references: [id])
  enrollment        EventEnrollment    @relation(fields: [enrollmentId], references: [id])
  user              User               @relation("UserPayments", fields: [userId], references: [id])

  @@index([eventId, status])
  @@index([userId, createdAt])
  @@index([enrollmentId, createdAt])
}

model OrganizerVoucher {
  id              String        @id @default(uuid())
  recipientUserId String
  organizerUserId String
  eventId         String?
  amount          Decimal       @db.Decimal(10, 2)
  remainingAmount Decimal       @db.Decimal(10, 2)
  source          VoucherSource @default(EVENT_CANCELLATION)
  status          VoucherStatus @default(ACTIVE)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sourcePaymentId String?
  event           Event?        @relation(fields: [eventId], references: [id])
  organizer       User          @relation("VoucherOrganizer", fields: [organizerUserId], references: [id])
  recipient       User          @relation("VoucherRecipient", fields: [recipientUserId], references: [id])
  sourcePayment   Payment?      @relation("VoucherSourcePayment", fields: [sourcePaymentId], references: [id])

  @@index([recipientUserId, organizerUserId, status])
  @@index([organizerUserId, status])
}

model MediaFile {
  id           String   @id @default(uuid())
  userId       String
  url          String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventGroupMessage {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([eventId, createdAt])
}

model PrivateChatMessage {
  id          String   @id @default(uuid())
  eventId     String
  senderId    String
  recipientId String
  content     String
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipient   User     @relation("PrivateChatRecipient", fields: [recipientId], references: [id])
  sender      User     @relation("PrivateChatSender", fields: [senderId], references: [id])

  @@index([eventId, senderId, recipientId, createdAt])
  @@index([eventId, recipientId, senderId, createdAt])
}

model PrivateChatReadReceipt {
  id          String   @id @default(uuid())
  eventId     String
  userId      String
  otherUserId String
  lastReadAt  DateTime @default(now())

  @@unique([eventId, userId, otherUserId])
  @@index([userId, eventId])
}

model Reprimand {
  id         String        @id @default(uuid())
  type       ReprimandType @default(REPRIMAND)
  fromUserId String
  toUserId   String
  eventId    String?
  reason     String
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  event      Event?        @relation(fields: [eventId], references: [id])
  fromUser   User          @relation("ReprimandFrom", fields: [fromUserId], references: [id])
  toUser     User          @relation("ReprimandTo", fields: [toUserId], references: [id])
}

model OrganizerUserRelation {
  id              String    @id @default(uuid())
  organizerUserId String
  targetUserId    String
  isBanned        Boolean   @default(false)
  isTrusted       Boolean   @default(false)
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  trustedAt       DateTime?
  bannedAt        DateTime?
  organizer       User      @relation("OrgRelOrganizer", fields: [organizerUserId], references: [id])
  targetUser      User      @relation("OrgRelTarget", fields: [targetUserId], references: [id])

  @@unique([organizerUserId, targetUserId])
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  type           NotificationKind
  title          String
  body           String
  relatedEventId String?
  createdAt      DateTime         @default(now())
  link           String?
  readAt         DateTime?
  updatedAt      DateTime         @updatedAt
  groupKey       String?
  aggregateCount Int              @default(1)
  relevanceUntil DateTime?
  deleteAfter    DateTime
  pushSentAt     DateTime?
  emailSentAt    DateTime?
  data           Json?
  relatedEvent   Event?           @relation("NotificationEvent", fields: [relatedEventId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([deleteAfter])
  @@index([userId, groupKey])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

model EventAnnouncement {
  id          String                @id @default(uuid())
  eventId     String
  organizerId String
  message     String
  priority    AnnouncementPriority  @default(INFORMATIONAL)
  trigger     AnnouncementTrigger   @default(MANUAL)
  createdAt   DateTime              @default(now())
  receipts    AnnouncementReceipt[]
  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer   User                  @relation("OrganizerAnnouncements", fields: [organizerId], references: [id])

  @@index([eventId, createdAt])
}

model AnnouncementReceipt {
  id             String            @id @default(uuid())
  announcementId String
  userId         String
  confirmToken   String            @unique @default(uuid())
  viewedAt       DateTime?
  confirmedAt    DateTime?
  createdAt      DateTime          @default(now())
  announcement   EventAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([confirmToken])
  @@index([announcementId, viewedAt])
}

model CitySubscription {
  id        String   @id @default(uuid())
  userId    String?
  citySlug  String
  createdAt DateTime @default(now())
  email     String?
  city      City     @relation(fields: [citySlug], references: [slug], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, citySlug])
  @@unique([email, citySlug])
  @@index([citySlug])
  @@index([email])
}

model ScheduledJob {
  id          String             @id @default(uuid())
  type        String
  payload     Json
  status      ScheduledJobStatus @default(PENDING)
  scheduledAt DateTime
  startedAt   DateTime?
  executedAt  DateTime?
  attempts    Int                @default(0)
  maxAttempts Int                @default(3)
  error       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, scheduledAt])
  @@index([type, status])
}

model CronLog {
  id          String    @id @default(uuid())
  cronName    String
  startedAt   DateTime
  completedAt DateTime?
  durationMs  Int?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([cronName, startedAt])
  @@index([createdAt])
}

model ContactMessage {
  id              String        @id @default(uuid())
  referenceNumber String?
  name            String
  email           String
  message         String
  userId          String?
  source          ContactSource @default(CONTACT_PAGE)
  citySlug        String?
  ipHash          String?
  emailSentAt     DateTime?
  emailSentCount  Int           @default(0)
  createdAt       DateTime      @default(now())
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([referenceNumber])
}

enum Role {
  USER
  ADMIN
}

enum AccountType {
  REAL
  GUEST
  FAKE
}

enum Gender {
  MALE
  FEMALE
}

enum EventGender {
  MALE
  FEMALE
  ANY
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventStatus {
  ACTIVE
  CANCELLED
  PENDING
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
}

enum VoucherSource {
  EVENT_CANCELLATION
  MANUAL_REFUND
  MANUAL_CREDIT
}

enum VoucherStatus {
  ACTIVE
  FULLY_USED
  EXPIRED
}

enum PaymentStatus {
  COMPLETED
  REFUNDED
  VOUCHER_REFUNDED
}

enum PaymentCurrency {
  PLN
}

enum NotificationKind {
  NEW_APPLICATION
  PARTICIPATION_STATUS
  EVENT_CANCELLED
  NEW_CHAT_MESSAGE
  NEW_PRIVATE_MESSAGE
  EVENT_REMINDER
  NEW_EVENT_IN_CITY
  REPRIMAND
  ANNOUNCEMENT
  PAYMENT_CANCELLED
  REAL_USER_JOINED_FAKE_EVENT
}

enum AnnouncementPriority {
  CRITICAL
  ORGANIZATIONAL
  INFORMATIONAL
}

enum AnnouncementTrigger {
  SYSTEM
  MANUAL
}

enum WithdrawnBy {
  USER
  ORGANIZER
  ADMIN
}

enum ReprimandType {
  REPRIMAND
  BAN
}

enum EventSeriesRecurrenceType {
  INTERVAL
  WEEKLY
}

enum ScheduledJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum ContactSource {
  CONTACT_PAGE
  CITY_EVENTS
  ADVERTISEMENT
}
