generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                  @id @default(uuid())
  email                       String                  @unique
  passwordHash                String?
  displayName                 String
  avatarUrl                   String?
  role                        String                  @default("USER")
  isActive                    Boolean                 @default(false)
  isEmailVerified             Boolean                 @default(false)
  activationToken             String?
  activationTokenExpiresAt    DateTime?
  passwordResetToken          String?
  passwordResetTokenExpiresAt DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  tpayMerchantId              String?
  announcementReceipts        AnnouncementReceipt[]
  chatMessages                ChatMessage[]
  citySubscriptions           CitySubscription[]
  organizedEvents             Event[]                 @relation("OrganizerEvents")
  announcements               EventAnnouncement[]     @relation("OrganizerAnnouncements")
  addedParticipants           EventParticipation[]    @relation("AddedByUser")
  participations              EventParticipation[]    @relation("UserParticipations")
  mediaFiles                  MediaFile[]
  notifications               Notification[]
  organizerRelations          OrganizerUserRelation[] @relation("OrgRelOrganizer")
  targetOfRelations           OrganizerUserRelation[] @relation("OrgRelTarget")
  vouchersIssued              OrganizerVoucher[]      @relation("VoucherOrganizer")
  vouchersReceived            OrganizerVoucher[]      @relation("VoucherRecipient")
  payments                    Payment[]               @relation("UserPayments")
  paymentIntents              PaymentIntent[]         @relation("UserPaymentIntents")
  privateChatMessagesReceived PrivateChatMessage[]    @relation("PrivateChatRecipient")
  privateChatMessagesSent     PrivateChatMessage[]    @relation("PrivateChatSender")
  pushSubscriptions           PushSubscription[]
  reprimandsGiven             Reprimand[]             @relation("ReprimandFrom")
  reprimandsReceived          Reprimand[]             @relation("ReprimandTo")
  socialAccounts              SocialAccount[]
  eventLimit                  UserEventLimit?
}

model SocialAccount {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model City {
  id            String             @id @default(uuid())
  name          String
  slug          String             @unique
  isActive      Boolean            @default(true)
  subscriptions CitySubscription[]
  events        Event[]
}

model EventDiscipline {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  coverImages CoverImage[]
  events      Event[]
}

model CoverImage {
  id           String          @id @default(uuid())
  disciplineId String
  filename     String
  originalName String
  createdAt    DateTime        @default(now())
  discipline   EventDiscipline @relation(fields: [disciplineId], references: [id])
  events       Event[]

  @@index([disciplineId])
}

model EventFacility {
  id     String  @id @default(uuid())
  name   String
  slug   String  @unique
  events Event[]
}

model EventLevel {
  id     String  @id @default(uuid())
  name   String
  slug   String  @unique
  events Event[]
}

model Event {
  id                  String               @id @default(uuid())
  title               String
  description         String?
  disciplineId        String
  facilityId          String
  levelId             String
  cityId              String
  organizerId         String
  startsAt            DateTime
  endsAt              DateTime
  costPerPerson       Decimal              @default(0) @db.Decimal(10, 2)
  minParticipants     Int?
  maxParticipants     Int
  ageMin              Int?
  ageMax              Int?
  gender              String               @default("ANY")
  visibility          String               @default("PUBLIC")
  status              EventStatus          @default(ACTIVE)
  address             String
  lat                 Float
  lng                 Float
  isRecurring         Boolean              @default(false)
  recurringRule       String?
  parentEventId       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  rules               String?
  coverImageId        String?
  lotteryExecutedAt   DateTime?
  roleConfig          Json?
  chatMessages        ChatMessage[]
  city                City                 @relation(fields: [cityId], references: [id])
  coverImage          CoverImage?          @relation(fields: [coverImageId], references: [id])
  discipline          EventDiscipline      @relation(fields: [disciplineId], references: [id])
  facility            EventFacility        @relation(fields: [facilityId], references: [id])
  level               EventLevel           @relation(fields: [levelId], references: [id])
  organizer           User                 @relation("OrganizerEvents", fields: [organizerId], references: [id])
  parentEvent         Event?               @relation("RecurringEvents", fields: [parentEventId], references: [id])
  childEvents         Event[]              @relation("RecurringEvents")
  announcements       EventAnnouncement[]
  participations      EventParticipation[]
  slots               EventSlot[]
  notifications       Notification[]       @relation("NotificationEvent")
  issuedVouchers      OrganizerVoucher[]
  payments            Payment[]            @relation("EventPayments")
  paymentIntents      PaymentIntent[]      @relation("EventPaymentIntents")
  privateChatMessages PrivateChatMessage[]
  reprimands          Reprimand[]

  @@index([cityId, status, startsAt])
}

model EventParticipation {
  id             String          @id @default(uuid())
  eventId        String
  userId         String
  addedByUserId  String?
  isGuest        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isChatBanned   Boolean         @default(false)
  wantsIn        Boolean         @default(true)
  withdrawnBy    String?
  roleKey        String?
  waitingReason  String?
  addedBy        User?           @relation("AddedByUser", fields: [addedByUserId], references: [id])
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User            @relation("UserParticipations", fields: [userId], references: [id])
  slot           EventSlot?
  payments       Payment[]
  paymentIntents PaymentIntent[]

  @@unique([eventId, userId])
}

model EventSlot {
  id              String              @id @default(uuid())
  eventId         String
  participationId String?             @unique
  confirmed       Boolean             @default(false)
  assignedAt      DateTime?
  createdAt       DateTime            @default(now())
  roleKey         String?
  event           Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participation   EventParticipation? @relation(fields: [participationId], references: [id])

  @@index([eventId])
  @@index([eventId, roleKey])
}

model PaymentIntent {
  id              String             @id @default(uuid())
  participationId String
  userId          String
  eventId         String
  amount          Decimal            @db.Decimal(10, 2)
  voucherReserved Decimal            @default(0) @db.Decimal(10, 2)
  operatorTxId    String?
  createdAt       DateTime           @default(now())
  event           Event              @relation("EventPaymentIntents", fields: [eventId], references: [id])
  participation   EventParticipation @relation(fields: [participationId], references: [id])
  user            User               @relation("UserPaymentIntents", fields: [userId], references: [id])

  @@index([operatorTxId])
  @@index([participationId])
}

model Payment {
  id                String             @id @default(uuid())
  participationId   String
  userId            String
  eventId           String
  amount            Decimal            @db.Decimal(10, 2)
  organizerAmount   Decimal            @db.Decimal(10, 2)
  platformFee       Decimal            @db.Decimal(10, 2)
  currency          String             @default("PLN")
  status            String             @default("COMPLETED")
  operatorTxId      String?
  method            String?
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  voucherAmountUsed Decimal            @default(0) @db.Decimal(10, 2)
  issuedVouchers    OrganizerVoucher[] @relation("VoucherSourcePayment")
  event             Event              @relation("EventPayments", fields: [eventId], references: [id])
  participation     EventParticipation @relation(fields: [participationId], references: [id])
  user              User               @relation("UserPayments", fields: [userId], references: [id])

  @@index([eventId, status])
  @@index([userId, createdAt])
  @@index([participationId, createdAt])
}

model OrganizerVoucher {
  id              String    @id @default(uuid())
  recipientUserId String
  organizerUserId String
  eventId         String?
  amount          Decimal   @db.Decimal(10, 2)
  remainingAmount Decimal   @db.Decimal(10, 2)
  source          String    @default("EVENT_CANCELLATION")
  status          String    @default("ACTIVE")
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sourcePaymentId String?
  event           Event?    @relation(fields: [eventId], references: [id])
  organizer       User      @relation("VoucherOrganizer", fields: [organizerUserId], references: [id])
  recipient       User      @relation("VoucherRecipient", fields: [recipientUserId], references: [id])
  sourcePayment   Payment?  @relation("VoucherSourcePayment", fields: [sourcePaymentId], references: [id])

  @@index([recipientUserId, organizerUserId, status])
  @@index([organizerUserId, status])
}

model MediaFile {
  id           String   @id @default(uuid())
  userId       String
  url          String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([eventId, createdAt])
}

model PrivateChatMessage {
  id          String   @id @default(uuid())
  eventId     String
  senderId    String
  recipientId String
  content     String
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipient   User     @relation("PrivateChatRecipient", fields: [recipientId], references: [id])
  sender      User     @relation("PrivateChatSender", fields: [senderId], references: [id])

  @@index([eventId, senderId, recipientId, createdAt])
  @@index([eventId, recipientId, senderId, createdAt])
}

model Reprimand {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  eventId    String
  reason     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id])
  fromUser   User     @relation("ReprimandFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("ReprimandTo", fields: [toUserId], references: [id])
}

model OrganizerUserRelation {
  id              String   @id @default(uuid())
  organizerUserId String
  targetUserId    String
  isBanned        Boolean  @default(false)
  isTrusted       Boolean  @default(false)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  organizer       User     @relation("OrgRelOrganizer", fields: [organizerUserId], references: [id])
  targetUser      User     @relation("OrgRelTarget", fields: [targetUserId], references: [id])

  @@unique([organizerUserId, targetUserId])
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  type           String
  title          String
  body           String
  isRead         Boolean  @default(false)
  relatedEventId String?
  createdAt      DateTime @default(now())
  relatedEvent   Event?   @relation("NotificationEvent", fields: [relatedEventId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

model EventAnnouncement {
  id          String                @id @default(uuid())
  eventId     String
  organizerId String
  message     String
  priority    String                @default("INFORMATIONAL")
  trigger     String                @default("MANUAL")
  createdAt   DateTime              @default(now())
  receipts    AnnouncementReceipt[]
  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer   User                  @relation("OrganizerAnnouncements", fields: [organizerId], references: [id])

  @@index([eventId, createdAt])
}

model AnnouncementReceipt {
  id             String            @id @default(uuid())
  announcementId String
  userId         String
  confirmToken   String            @unique @default(uuid())
  viewedAt       DateTime?
  confirmedAt    DateTime?
  createdAt      DateTime          @default(now())
  announcement   EventAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([confirmToken])
  @@index([announcementId, viewedAt])
}

model CitySubscription {
  id        String   @id @default(uuid())
  userId    String
  cityId    String
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([cityId])
}

model SystemSetting {
  key   String @id
  value String
}

model UserEventLimit {
  id              String @id @default(uuid())
  userId          String @unique
  maxActiveEvents Int
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventStatus {
  ACTIVE
  CANCELLED
}
