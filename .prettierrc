{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,

  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "arrowParens": "always",

  "bracketSpacing": true,
  "bracketSameLine": false,

  "htmlWhitespaceSensitivity": "css",
  "endOfLine": "lf",

  "overrides": [
    {
      "files": "*.html",
      "options": {
        "printWidth": 120,
        "parser": "angular"
      }
    },
    {
      "files": "*.scss",
      "options": {
        "printWidth": 120
      }
    }
  ]
}
